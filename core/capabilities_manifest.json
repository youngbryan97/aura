{
    "version": "1.1",
    "capabilities": {
        "file_system": {
            "allowed_read": [
                "core/",
                "interface/",
                "utils/",
                "skills/",
                "config/",
                "data/",
                "logs/",
                "tmp/",
                "artifacts/"
            ],
            "allowed_write": [
                "data/",
                "logs/",
                "tmp/",
                "artifacts/"
            ],
            "restricted_paths": [
                "*.key",
                "core/security/**",
                "core/guardians/**",
                "core/prime_directives.py"
            ]
        },
        "network": {
            "allowed_domains": [
                "github.com",
                "huggingface.co",
                "pypi.org",
                "python.org",
                "google.com"
            ],
            "restricted_ports": [
                22,
                25,
                445,
                3389
            ]
        },
        "process": {
            "allow_subprocess": true,
            "max_concurrent_tasks": 10,
            "resource_limits": {
                "max_memory_mb": 2048,
                "max_cpu_percent": 80
            }
        },
        "self_modification": {
            "allowed": false,
            "requires_approval": true,
            "safe_mode_enabled": true,
            "rollback_depth": 5
        }
    },
    "enforcement_level": "enforce"
}